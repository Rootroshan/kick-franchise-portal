# Copy to .env.local for development. Never commit real secrets.

# Database — two URLs: one pooled for app (RLS-enforced, non-superuser), one direct for migrations (owner)
DATABASE_URL="postgresql://app_user:password@localhost:5432/kick?sslmode=prefer"
DIRECT_URL="postgresql://postgres:password@localhost:5432/kick?sslmode=prefer"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kick-assets
R2_ENDPOINT=

# Redis / queue
REDIS_URL="redis://localhost:6379"

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL="Kick Portal <notifications@portal.kickmedia.com>"

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:ops@kickmedia.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# App
APP_BASE_DOMAIN="portal.kickmedia.com"
PORTAL_CNAME_TARGET="cname.vercel-dns.com"
NODE_ENV=development
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Kick admin bootstrap (used only by seed script to flag the first Kick admin)
KICK_ADMIN_CLERK_USER_ID=
