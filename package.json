    "bullmq": "^5.34.5",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.468.0",
    "next": "^14.2.18",
    "posthog-js": "^1.192.1",
    "posthog-node": "^4.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "stripe": "^17.4.0",
    "svix": "^1.42.0",
