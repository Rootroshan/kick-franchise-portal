{
  "name": "kick-franchise-portal",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:lockout": "vitest run tests/lockout",
    "test:money": "vitest run tests/money",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "rls:apply": "tsx scripts/apply-rls.ts",
    "rls:verify": "tsx scripts/verify-rls.ts",
    "worker": "tsx worker/index.ts",
    "migrate-shopify": "tsx scripts/migrate-shopify.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.12.6",
